# PostgreSQL connection string (Neon, Vercel Postgres, or Supabase)
# On Vercel: add a Postgres store and it sets this automatically.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Admin dashboard password — change this to something strong.
ADMIN_PASSWORD="change-me-to-a-strong-password"

# Random secret used to sign the admin session cookie.
# Generate one with:  openssl rand -hex 32
SESSION_SECRET="replace-with-a-long-random-string"
